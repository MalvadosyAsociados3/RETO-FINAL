<?xml version="1.0"?>
<robot name="puzzlebot">

  <link name="base_footprint"/>                                                                                     <!-- Frame visual que representa el robot proyectado en el suelo -->

 <!-- Base Link -->
  <link name="base_link">
    <inertial>
      <mass value="1.0"/>                                                                                           <!-- Física del robot -->
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Jetson_Lidar_Edition_Base(1).stl" scale="1 1 1"/>  <!-- Esto es lo que se ve virtual en RVIZ -->
      </geometry>
      <material name="azul_noche">
        <color rgba="0.05 0.05 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Jetson_Lidar_Edition_Base(1).stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>


  <!-- Right Wheel Link -->
  <link name="wheel_r">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>
      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="cyan">
        <color rgba="0.0 0.8 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>


  <!-- Left Wheel Link -->
  <link name="wheel_l">
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="1.5708 0.0 0.0"/>

      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="cyan">
        <color rgba="0.0 0.8 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>


  <!-- Caster Wheel Link -->
  <link name="caster">
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0.0 0.0 0.0" rpy="0.0 0.0 0.0"/>
      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
      <material name="black">
        <color rgba="1.0 1.0 1.0 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <mesh filename="package://minic3/meshes/Puzzlebot_Caster_Wheel.stl" scale="1 1 1"/>
      </geometry>
    </collision>
  </link>


  <!-- JOINTS -->

  <!-- Fixed joint between base_footprint and base_link (z-axis offset) -->
  <joint name="base_link_joint" type="fixed">
    <origin xyz="0.0 0.0 0.05" rpy="0.0 0.0 0.0"/>
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <!-- Right Wheel Joint -->
  <joint name="wheel_r_joint" type="continuous">
    <origin xyz="0.052 -0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_r"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- Left Wheel Joint -->
  <joint name="wheel_l_joint" type="continuous">
    <origin xyz="0.052 0.095 -0.0025" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="wheel_l"/>
    <axis xyz="0.0 1.0 0.0"/>
  </joint>

  <!-- Caster Joint -->
  <joint name="caster_joint" type="fixed">
    <origin xyz="-0.09 0 -0.043" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="caster"/>
  </joint>

    <!-- ================= LIDAR ================= -->

  <link name="laser">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.035" length="0.03"/>
      </geometry>
      <material name="gray">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <origin xyz="0.08 0.0 0.09" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="laser"/>
  </joint>


  <!-- ================= CAMERA ================= -->

  <link name="camera">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.03 0.04 0.03"/>
      </geometry>
      <material name="black_camera">
        <color rgba="0.0 0.0 0.0 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="camera_joint" type="fixed">
    <origin xyz="0.10 0.0 0.12" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="camera"/>
  </joint>


  <!-- Frame óptico de cámara.
       En ROS normalmente:
       z = hacia enfrente de la cámara
       x = derecha de la imagen
       y = abajo de la imagen
  -->
  <link name="camera_optical_frame"/>

  <joint name="camera_optical_joint" type="fixed">
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    <parent link="camera"/>
    <child link="camera_optical_frame"/>
  </joint>

</robot>